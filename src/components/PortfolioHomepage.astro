---
// Server-side rendered portfolio for homepage - optimized for performance
// Uses internal API fetch for reliable data loading

let projects: any[] = [];
let categories: any[] = [];
let debugInfo = '';

try {
  // Get the request URL to build the API URL
  const url = Astro.url;
  const baseUrl = `${url.protocol}//${url.host}`;

  // Fetch from the internal API (which we know works)
  const [projectsRes, categoriesRes] = await Promise.all([
    fetch(`${baseUrl}/api/admin/portfolio?status=published&limit=4`),
    fetch(`${baseUrl}/api/admin/portfolio/categories`)
  ]);

  if (projectsRes.ok) {
    const projectsData = await projectsRes.json();
    projects = projectsData.projects || projectsData.results || [];
  } else {
    debugInfo = `Projects fetch failed: ${projectsRes.status}`;
  }

  if (categoriesRes.ok) {
    const categoriesData = await categoriesRes.json();
    categories = categoriesData.categories || categoriesData.results || [];
  }
} catch (e) {
  console.error('Failed to fetch portfolio data:', e);
  debugInfo = `Error: ${e instanceof Error ? e.message : String(e)}`;
}
---

<section id="portfolio" class="section portfolio">
  <div class="container">
    <div class="section-header" data-animate>
      <h2 data-text-reveal class="animated-header title-hero">
        <span class="title-icon">💼</span>
        <span class="title-gradient">Our Work Speaks Volumes</span>
        <span class="title-icon">💼</span>
        <div class="title-underline"></div>
      </h2>
      <p class="section-description">
        Explore our portfolio of successful projects that transformed businesses
      </p>
    </div>

    <!-- Portfolio Grid - Server-rendered, no loading spinner needed -->
    <div class="portfolio-grid">
      {projects.length > 0 ? (
        projects.map((project, index) => {
          const category = categories.find(c => c.id === project.category_id);
          const categoryName = category?.name || 'Project';
          const techStack = project.tech_stack ? project.tech_stack.split(',').map((t: string) => t.trim()) : [];
          const hasMetrics = project.metric_1_label || project.metric_2_label || project.metric_3_label || project.metric_4_label;

          // Determine loading strategy for images
          const isAboveFold = index < 2;
          const loadingAttr = isAboveFold ? 'eager' : 'lazy';
          const fetchPriorityAttr = isAboveFold ? 'high' : 'auto';
          const decodingAttr = isAboveFold ? 'sync' : 'async';

          return (
            <article class="portfolio-item glass" data-animate style={`--animation-delay: ${index * 100}ms`}>
              <div class="portfolio-image-wrapper">
                <img
                  src={project.featured_image}
                  alt={project.title}
                  loading={loadingAttr}
                  fetchpriority={fetchPriorityAttr}
                  decoding={decodingAttr}
                  class="portfolio-image"
                />
                <div class="portfolio-overlay">
                  <span class="category-badge">{categoryName}</span>
                </div>
              </div>

              <div class="portfolio-content">
                <h3 class="portfolio-title">{project.title}</h3>
                <p class="portfolio-description">{project.description}</p>

                {techStack.length > 0 && (
                  <div class="tech-stack">
                    {techStack.map((tech: string) => (
                      <span class="tech-badge">{tech}</span>
                    ))}
                  </div>
                )}

                {hasMetrics && (
                  <div class="portfolio-metrics">
                    {project.metric_1_label && project.metric_1_value && (
                      <div class="metric-item">
                        <span class="metric-value">{project.metric_1_value}</span>
                        <span class="metric-label">{project.metric_1_label}</span>
                      </div>
                    )}
                    {project.metric_2_label && project.metric_2_value && (
                      <div class="metric-item">
                        <span class="metric-value">{project.metric_2_value}</span>
                        <span class="metric-label">{project.metric_2_label}</span>
                      </div>
                    )}
                    {project.metric_3_label && project.metric_3_value && (
                      <div class="metric-item">
                        <span class="metric-value">{project.metric_3_value}</span>
                        <span class="metric-label">{project.metric_3_label}</span>
                      </div>
                    )}
                    {project.metric_4_label && project.metric_4_value && (
                      <div class="metric-item">
                        <span class="metric-value">{project.metric_4_value}</span>
                        <span class="metric-label">{project.metric_4_label}</span>
                      </div>
                    )}
                  </div>
                )}

                <a href={`/portfolio/${project.slug}`} class="portfolio-link">
                  View Project
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </div>
            </article>
          );
        })
      ) : (
        <div class="empty-state">
          <p>No projects available at the moment.</p>
        </div>
      )}
    </div>

    <div class="portfolio-cta" data-animate>
      <p>Want to see more of our work?</p>
      <a href="/portfolio" class="btn btn-primary view-all-btn">
        View All Projects
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

    <!-- Floating Achievement Badges -->
    <div class="floating-badges">
      <div class="badge badge-1">
        <div class="badge-icon">🏆</div>
        <div class="badge-text">
          <strong>Award Winning</strong>
          <span>Design Excellence</span>
        </div>
      </div>
      <div class="badge badge-2">
        <div class="badge-icon">⚡</div>
        <div class="badge-text">
          <strong>Lightning Fast</strong>
          <span>Performance</span>
        </div>
      </div>
      <div class="badge badge-3">
        <div class="badge-icon">💎</div>
        <div class="badge-text">
          <strong>Premium Quality</strong>
          <span>Guaranteed</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Import all styles from original Portfolio component */
  .portfolio {
    background: linear-gradient(180deg,
      #ffffff 0%,
      rgba(227, 169, 43, 0.02) 20%,
      rgba(227, 169, 43, 0.05) 50%,
      rgba(227, 169, 43, 0.02) 80%,
      #ffffff 100%
    );
    padding: var(--spacing-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .portfolio {
    background: linear-gradient(180deg,
      var(--color-background) 0%,
      rgba(227, 169, 43, 0.03) 20%,
      rgba(227, 169, 43, 0.06) 50%,
      rgba(227, 169, 43, 0.03) 80%,
      var(--color-background) 100%
    );
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .animated-header {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: var(--spacing-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .title-icon {
    font-size: 0.8em;
    animation: pulse 2s ease-in-out infinite;
  }

  .title-gradient {
    background: var(--gradient-primary);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .title-underline {
    height: 4px;
    width: 120px;
    background: var(--gradient-primary);
    margin: var(--spacing-md) auto 0;
    border-radius: 2px;
  }

  .section-description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-3xl);
  }

  .portfolio-item {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
    animation: fadeInUp 0.6s ease-out forwards;
    animation-delay: var(--animation-delay, 0ms);
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .portfolio-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  .portfolio-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .portfolio-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .portfolio-item:hover .portfolio-image {
    transform: scale(1.05);
  }

  .portfolio-overlay {
    position: absolute;
    top: var(--spacing-md);
    right: var(--spacing-md);
  }

  .category-badge {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-primary);
  }

  :global([data-theme="dark"]) .category-badge {
    background: rgba(0, 0, 0, 0.8);
    color: var(--color-primary-light);
  }

  .portfolio-content {
    padding: var(--spacing-xl);
  }

  .portfolio-title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-primary);
  }

  .portfolio-description {
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
    line-height: 1.6;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
  }

  .tech-badge {
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: var(--spacing-2xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  :global([data-theme="dark"]) .tech-badge {
    background: rgba(227, 169, 43, 0.15);
    color: var(--color-primary-light);
  }

  .portfolio-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    background: rgba(227, 169, 43, 0.05);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-md);
  }

  .metric-item {
    text-align: center;
  }

  .metric-value {
    display: block;
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--spacing-2xs);
  }

  .metric-label {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .portfolio-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    min-height: 44px;
    padding: 0.5rem 0;
    transition: all var(--transition-fast);
  }

  .portfolio-link:hover {
    gap: var(--spacing-sm);
    color: var(--color-primary-dark);
  }

  .portfolio-link svg {
    transition: transform var(--transition-fast);
  }

  .portfolio-link:hover svg {
    transform: translateX(4px);
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-3xl);
    color: var(--color-text-secondary);
    grid-column: 1 / -1;
  }

  .portfolio-cta {
    text-align: center;
    padding: var(--spacing-2xl);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  .portfolio-cta p {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }

  .view-all-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  /* Floating Badges */
  .floating-badges {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    background: var(--color-surface);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: var(--radius-full);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    animation: float 6s ease-in-out infinite;
  }

  .badge-1 {
    top: 10%;
    right: 5%;
    animation-delay: 0s;
  }

  .badge-2 {
    bottom: 20%;
    left: 3%;
    animation-delay: 2s;
  }

  .badge-3 {
    top: 50%;
    right: 8%;
    animation-delay: 4s;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(5deg);
    }
  }

  .badge-icon {
    font-size: 1.5rem;
  }

  .badge-text {
    display: flex;
    flex-direction: column;
  }

  .badge-text strong {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .badge-text span {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  /* Reduced-motion: suppress hover transforms (transitions already collapse to 0.01ms globally) */
  @media (prefers-reduced-motion: reduce) {
    .portfolio-item:hover {
      transform: none;
    }
    .portfolio-item:hover .portfolio-image {
      transform: none;
    }
    .portfolio-link:hover svg {
      transform: none;
    }
  }

  /* Mobile Optimization */
  @media (max-width: 768px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }

    .floating-badges {
      display: none;
    }

    .animated-header {
      font-size: 2rem;
    }

    .portfolio-item {
      animation-delay: 0ms !important;
    }
  }
</style>

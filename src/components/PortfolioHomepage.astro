---
// Server-side rendered portfolio for homepage - optimized for performance
// Uses internal API fetch for reliable data loading

let projects: any[] = [];
let categories: any[] = [];
let debugInfo = '';

try {
  // Get the request URL to build the API URL
  const url = Astro.url;
  const baseUrl = `${url.protocol}//${url.host}`;

  // Fetch from the internal API (which we know works)
  const [projectsRes, categoriesRes] = await Promise.all([
    fetch(`${baseUrl}/api/admin/portfolio?status=published&limit=3`),
    fetch(`${baseUrl}/api/admin/portfolio/categories`)
  ]);

  if (projectsRes.ok) {
    const projectsData = await projectsRes.json();
    projects = projectsData.projects || projectsData.results || [];
  } else {
    debugInfo = `Projects fetch failed: ${projectsRes.status}`;
  }

  if (categoriesRes.ok) {
    const categoriesData = await categoriesRes.json();
    categories = categoriesData.categories || categoriesData.results || [];
  }
} catch (e) {
  console.error('Failed to fetch portfolio data:', e);
  debugInfo = `Error: ${e instanceof Error ? e.message : String(e)}`;
}
---

<section id="portfolio" class="section portfolio">
  <div class="container">
    <div class="section-header" data-animate>
      <h2 data-text-reveal class="animated-header title-hero">
        <span class="title-icon">💼</span>
        <span class="title-gradient">Our Work Speaks Volumes</span>
        <span class="title-icon">💼</span>
        <div class="title-underline"></div>
      </h2>
      <p class="section-description">
        Explore our portfolio of successful projects that transformed businesses
      </p>
    </div>

    <!-- Portfolio Grid - Server-rendered, no loading spinner needed -->
    <div class="portfolio-grid">
      {projects.length > 0 ? (
        projects.map((project, index) => {
          const category = categories.find(c => c.id === project.category_id);
          const categoryName = category?.name || 'Project';
          const metricValue = project.metric_1_value || '';
          const metricLabel = project.metric_1_label || '';
          // Outcome-first: big metric when available, one-line subtitle otherwise
          const fallbackLine = project.subtitle || project.description || '';

          // Determine loading strategy for images (index 0 stays the LCP candidate)
          const isAboveFold = index < 2;
          const loadingAttr = isAboveFold ? 'eager' : 'lazy';
          const fetchPriorityAttr = isAboveFold ? 'high' : 'auto';
          const decodingAttr = isAboveFold ? 'sync' : 'async';

          return (
            <a
              href={`/portfolio/${project.slug}`}
              class="portfolio-tile"
              data-animate
              style={`--animation-delay: ${index * 100}ms`}
            >
              <img
                src={project.featured_image}
                alt={project.title}
                loading={loadingAttr}
                fetchpriority={fetchPriorityAttr}
                decoding={decodingAttr}
                class="tile-image"
              />
              <span class="tile-category">{categoryName}</span>
              <div class="tile-content">
                <h3 class="tile-title">{project.title}</h3>
                <p class="tile-outcome">
                  {metricValue ? (
                    <>
                      <span class="tile-metric">{metricValue}</span>
                      {metricLabel && <span class="tile-metric-label">{metricLabel}</span>}
                    </>
                  ) : (
                    <span class="tile-subtitle">{fallbackLine}</span>
                  )}
                  <svg class="tile-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </p>
              </div>
              <span class="tile-kente" aria-hidden="true"></span>
            </a>
          );
        })
      ) : (
        <div class="empty-state">
          <p>No projects available at the moment.</p>
        </div>
      )}
    </div>

    <div class="portfolio-cta" data-animate>
      <p>Want to see more of our work?</p>
      <a href="/portfolio" class="btn btn-primary view-all-btn">
        View All Projects
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

    <!-- Floating Achievement Badges -->
    <div class="floating-badges">
      <div class="badge badge-1">
        <div class="badge-icon">🏆</div>
        <div class="badge-text">
          <strong>Award Winning</strong>
          <span>Design Excellence</span>
        </div>
      </div>
      <div class="badge badge-2">
        <div class="badge-icon">⚡</div>
        <div class="badge-text">
          <strong>Lightning Fast</strong>
          <span>Performance</span>
        </div>
      </div>
      <div class="badge badge-3">
        <div class="badge-icon">💎</div>
        <div class="badge-text">
          <strong>Premium Quality</strong>
          <span>Guaranteed</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Import all styles from original Portfolio component */
  .portfolio {
    background: linear-gradient(180deg,
      #ffffff 0%,
      rgba(227, 169, 43, 0.02) 20%,
      rgba(227, 169, 43, 0.05) 50%,
      rgba(227, 169, 43, 0.02) 80%,
      #ffffff 100%
    );
    padding: var(--spacing-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .portfolio {
    background: linear-gradient(180deg,
      var(--color-background) 0%,
      rgba(227, 169, 43, 0.03) 20%,
      rgba(227, 169, 43, 0.06) 50%,
      rgba(227, 169, 43, 0.03) 80%,
      var(--color-background) 100%
    );
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .animated-header {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: var(--spacing-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .title-icon {
    font-size: 0.8em;
    animation: pulse 2s ease-in-out infinite;
  }

  .title-gradient {
    background: var(--gradient-primary);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .title-underline {
    height: 4px;
    width: 120px;
    background: var(--gradient-primary);
    margin: var(--spacing-md) auto 0;
    border-radius: 2px;
  }

  .section-description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-3xl);
  }

  @media (min-width: 641px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Gallery tile: the image IS the card. Cocoa scrim + outcome metric on top,
     kente strip as the baseline. Self-contained dark-on-image in both themes. */
  .portfolio-tile {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    background: #161210;
    transition: box-shadow var(--transition-normal);
    animation: fadeInUp 0.6s ease-out forwards;
    animation-delay: var(--animation-delay, 0ms);
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .portfolio-tile:hover {
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
  }

  .portfolio-tile:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 3px;
  }

  .tile-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .portfolio-tile:hover .tile-image {
    transform: scale(1.04);
  }

  /* Base cocoa scrim */
  .portfolio-tile::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(transparent 40%, rgba(22, 18, 16, 0.94));
  }

  /* Hover darkening layer (gradients can't transition; opacity can) */
  .portfolio-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(transparent 30%, rgba(22, 18, 16, 0.7));
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .portfolio-tile:hover::after {
    opacity: 1;
  }

  .tile-category.tile-category.tile-category.tile-category {
    position: absolute;
    top: var(--spacing-md);
    right: var(--spacing-md);
    z-index: 2;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #FAF3E0;
    background: rgba(22, 18, 16, 0.55);
    backdrop-filter: blur(8px);
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-full);
  }

  .tile-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: var(--spacing-lg);
    padding-bottom: calc(var(--spacing-lg) + 3px); /* clear the kente baseline */
  }

  .tile-title {
    margin: 0 0 var(--spacing-xs);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.3;
    color: #FAF3E0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tile-outcome {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-sm);
    margin: 0;
    min-width: 0;
  }

  /* Doubled classes beat the global dark-mode span override
     ([data-theme="dark"] span:not(...) in dark-mode-fixes.css, specificity 0,4,1).
     These colors are fixed brand-on-image and must not re-theme. */
  .tile-metric.tile-metric.tile-metric.tile-metric {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    color: #E3A92B;
  }

  .tile-metric-label.tile-metric-label.tile-metric-label.tile-metric-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(250, 243, 224, 0.75);
  }

  /* Fallback when a project has no metric_1_value: one-line subtitle, never an empty gap */
  .tile-subtitle.tile-subtitle.tile-subtitle.tile-subtitle {
    flex: 1;
    min-width: 0;
    font-size: 0.95rem;
    color: rgba(250, 243, 224, 0.85);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tile-arrow {
    flex-shrink: 0;
    align-self: center;
    color: #E3A92B;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity var(--transition-normal), transform var(--transition-normal);
  }

  .portfolio-tile:hover .tile-arrow,
  .portfolio-tile:focus-visible .tile-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* Kente baseline — same brand strip as motifs.css, scaled to 3px */
  .tile-kente {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 3px;
    z-index: 3;
    background: repeating-linear-gradient(
      90deg,
      #E3A92B 0 24px,
      #1B5E3A 24px 36px,
      #161210 36px 48px,
      #CE1126 48px 54px,
      #E3A92B 54px 78px
    );
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-3xl);
    color: var(--color-text-secondary);
    grid-column: 1 / -1;
  }

  .portfolio-cta {
    text-align: center;
    padding: var(--spacing-2xl);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  .portfolio-cta p {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }

  .view-all-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  /* Floating Badges */
  .floating-badges {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    background: var(--color-surface);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: var(--radius-full);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    animation: float 6s ease-in-out infinite;
  }

  .badge-1 {
    top: 10%;
    right: 5%;
    animation-delay: 0s;
  }

  .badge-2 {
    bottom: 20%;
    left: 3%;
    animation-delay: 2s;
  }

  /* Mirrors badge-2 near the CTA — the shorter gallery tiles mean top:50%
     would sit on the third card and obscure its title/metric */
  .badge-3 {
    bottom: 12%;
    right: 5%;
    animation-delay: 4s;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(5deg);
    }
  }

  .badge-icon {
    font-size: 1.5rem;
  }

  .badge-text {
    display: flex;
    flex-direction: column;
  }

  .badge-text strong {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .badge-text span {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  /* Reduced-motion: suppress hover transforms (transitions already collapse to 0.01ms globally) */
  @media (prefers-reduced-motion: reduce) {
    .portfolio-tile:hover .tile-image {
      transform: none;
    }
    .tile-arrow {
      transform: none;
    }
    .portfolio-tile:hover .tile-arrow,
    .portfolio-tile:focus-visible .tile-arrow {
      transform: none;
    }
  }

  /* Mobile Optimization */
  @media (max-width: 768px) {
    .floating-badges {
      display: none;
    }

    .animated-header {
      font-size: 2rem;
    }

    .portfolio-tile {
      animation-delay: 0ms !important;
    }
  }

  @media (max-width: 640px) {
    .portfolio-tile {
      aspect-ratio: 16 / 10;
    }

    .tile-metric.tile-metric.tile-metric.tile-metric {
      font-size: 1.6rem;
    }
  }
</style>

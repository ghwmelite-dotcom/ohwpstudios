---
// AI Chatbot Widget Component - Elite Modern Design
---

<div class="chatbot-container" id="chatbot-container">
  <svg class="chatbot-circle-text" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <path id="circlePath" d="M 100, 100 m -75, 0 a 75,75 0 1,1 150,0 a 75,75 0 1,1 -150,0" />
      <linearGradient id="textGradient" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#6366f1;stop-opacity:1" />
        <stop offset="50%" style="stop-color:#818cf8;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#f59e0b;stop-opacity:1" />
      </linearGradient>
    </defs>
    <text class="circle-text">
      <textPath href="#circlePath" startOffset="0%">
        ohwp live chat • ohwp live chat • ohwp live chat •
      </textPath>
    </text>
  </svg>
  <button class="chatbot-toggle" id="chatbot-toggle" aria-label="Toggle chatbot">
    <div class="chatbot-toggle-inner">
      <svg class="chat-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="url(#chatGradient1)" opacity="0.8"/>
        <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="12" cy="7" r="1.5" fill="currentColor"/>
        <defs>
          <linearGradient id="chatGradient1" x1="2" y1="2" x2="22" y2="12">
            <stop offset="0%" stop-color="#6366f1"/>
            <stop offset="100%" stop-color="#ec4899"/>
          </linearGradient>
        </defs>
      </svg>
      <svg class="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
      <div class="chatbot-glow"></div>
    </div>
    <span class="chatbot-badge">1</span>
  </button>

  <div class="chatbot-window" id="chatbot-window">
    <div class="chatbot-header">
      <div class="chatbot-avatar">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="currentColor" opacity="0.9"/>
          <path d="M2 17L12 22L22 17M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="12" cy="7" r="2" fill="white"/>
        </svg>
        <div class="avatar-glow"></div>
      </div>
      <div class="chatbot-info">
        <h4>Kodie - AI Assistant</h4>
        <span class="chatbot-status">
          <span class="status-dot"></span>
          <span>Online Now</span>
        </span>
      </div>
      <button class="chatbot-minimize" aria-label="Minimize chat">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
    </div>

    <!-- Welcome Screen -->
    <div class="chatbot-welcome" id="chatbot-welcome">
      <div class="welcome-header">
        <div class="welcome-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="url(#welcomeGrad)" opacity="0.9"/>
            <path d="M2 17L12 22L22 17M2 12L12 17L22 12" stroke="url(#welcomeGrad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="7" r="3" fill="white"/>
            <defs>
              <linearGradient id="welcomeGrad" x1="2" y1="2" x2="22" y2="22">
                <stop offset="0%" stop-color="#667eea"/>
                <stop offset="100%" stop-color="#f093fb"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h3>Welcome! 👋</h3>
        <p>I'm Kodie, your AI assistant. I can help with web development, WordPress, SEO, debugging, and technical questions.</p>
      </div>
      <form class="welcome-form" id="welcome-form">
        <div class="form-group">
          <input type="text" id="user-name" placeholder="Your name" required />
        </div>
        <div class="form-group">
          <input type="email" id="user-email" placeholder="Your email (optional)" />
        </div>
        <button type="submit" class="start-chat-btn">
          Start Chat
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </button>
      </form>
    </div>

    <div class="chatbot-messages" id="chatbot-messages" style="display: none;">
      <!-- Messages will be added here dynamically -->
    </div>

    <form class="chatbot-input" id="chatbot-form" style="display: none;">
      <input
        type="text"
        id="chatbot-message"
        placeholder="Type your message..."
        autocomplete="off"
        required
      />
      <button type="submit" aria-label="Send message">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </form>

    <div class="chatbot-actions" id="chatbot-actions" style="display: none;">
      <button class="export-btn" id="export-whatsapp" title="Send to WhatsApp">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </button>
      <button class="export-btn" id="export-telegram" title="Send to Telegram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161l-1.64 7.735c-.123.557-.449.692-.907.432l-2.51-1.849-1.21 1.166c-.134.134-.246.246-.505.246l.179-2.545 4.651-4.201c.202-.18-.044-.28-.314-.099l-5.747 3.62-2.475-.772c-.538-.168-.55-.538.113-.797l9.681-3.732c.448-.168.842.104.695.789z"/>
        </svg>
        Telegram
      </button>
      <button class="export-btn" id="export-email" title="Email transcript">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        Email
      </button>
      <button class="export-btn" id="export-copy" title="Copy transcript">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        Copy
      </button>
    </div>

    <div class="chatbot-footer">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      <span>Powered by Hodges & Co.</span>
    </div>
  </div>
</div>

<style>
  .chatbot-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 9999;
    overflow: visible;
  }

  .chatbot-circle-text {
    position: absolute;
    width: 160px;
    height: 160px;
    top: -46px;
    left: -46px;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.3s ease;
    animation: rotate 20s linear infinite;
    z-index: 1;
  }

  .chatbot-container:hover .chatbot-circle-text {
    opacity: 1;
  }

  .chatbot-toggle.active ~ .chatbot-circle-text {
    opacity: 0;
  }

  .circle-text {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    fill: #f59e0b;
  }

  @keyframes rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .chatbot-label {
    position: absolute;
    bottom: 50%;
    right: 85px;
    transform: translateY(50%);
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 0.625rem 1.125rem;
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(102, 126, 234, 0.3);
    pointer-events: none;
    opacity: 0.95;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .chatbot-label::after {
    content: '';
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .chatbot-toggle:hover ~ .chatbot-label,
  .chatbot-container:hover .chatbot-label {
    opacity: 1;
    transform: translateY(50%) translateX(-4px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
  }

  .chatbot-toggle.active ~ .chatbot-label {
    opacity: 0;
    pointer-events: none;
  }

  .chatbot-toggle {
    width: 68px;
    height: 68px;
    border-radius: var(--radius-full);
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    z-index: 2;
  }

  .chatbot-toggle-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 40px rgba(102, 126, 234, 0.4), 0 0 0 0 rgba(102, 126, 234, 0.4);
    animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse-ring {
    0%, 100% {
      box-shadow: 0 10px 40px rgba(102, 126, 234, 0.4), 0 0 0 0 rgba(102, 126, 234, 0.4);
    }
    50% {
      box-shadow: 0 10px 40px rgba(102, 126, 234, 0.5), 0 0 0 10px rgba(102, 126, 234, 0);
    }
  }

  .chatbot-toggle:hover .chatbot-toggle-inner {
    transform: scale(1.05) rotate(5deg);
    box-shadow: 0 15px 50px rgba(102, 126, 234, 0.6), 0 0 0 0 rgba(102, 126, 234, 0.4);
  }

  .chatbot-glow {
    position: absolute;
    inset: -2px;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, #667eea, #764ba2, #f093fb);
    filter: blur(12px);
    opacity: 0.7;
    z-index: -1;
    animation: rotate-glow 3s linear infinite;
  }

  @keyframes rotate-glow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .chatbot-toggle .close-icon {
    display: none;
  }

  .chatbot-toggle.active .chat-icon {
    display: none;
  }

  .chatbot-toggle.active .close-icon {
    display: block;
  }

  .chatbot-toggle.active .chatbot-toggle-inner {
    background: linear-gradient(135deg, #f093fb 0%, #764ba2 50%, #667eea 100%);
  }

  .chatbot-badge {
    position: absolute;
    top: -6px;
    right: -6px;
    min-width: 26px;
    height: 26px;
    padding: 0 6px;
    background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
    color: white;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    border: 3px solid var(--color-bg);
    box-shadow: 0 4px 12px rgba(255, 107, 107, 0.5);
    animation: bounce-badge 2s ease-in-out infinite;
  }

  @keyframes bounce-badge {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .chatbot-badge.hidden {
    display: none;
  }

  .chatbot-window {
    position: absolute;
    bottom: 90px;
    right: 0;
    width: 420px;
    height: min(600px, calc(100vh - 180px));
    max-height: calc(100vh - 180px);
    background: var(--color-surface);
    border-radius: 24px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255, 255, 255, 0.1);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(30px) scale(0.9);
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    backdrop-filter: blur(20px);
  }

  .chatbot-window::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.03), rgba(118, 75, 162, 0.03));
    pointer-events: none;
  }

  .chatbot-window.active {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  .chatbot-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 0.875rem;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.05));
    border-radius: 20px 20px 0 0;
    position: relative;
    z-index: 1;
    min-height: 70px;
  }

  .chatbot-avatar {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.5rem;
    position: relative;
    box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
    flex-shrink: 0;
  }

  .avatar-glow {
    position: absolute;
    inset: -3px;
    border-radius: 18px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    filter: blur(8px);
    opacity: 0.4;
    z-index: -1;
    animation: pulse-avatar 2s ease-in-out infinite;
  }

  @keyframes pulse-avatar {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.6; }
  }

  .chatbot-info {
    flex: 1;
  }

  .chatbot-info h4 {
    font-size: 0.95rem;
    margin: 0 0 0.25rem 0;
    color: var(--color-text);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .chatbot-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.825rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #10b981, #34d399);
    box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(1.2);
    }
  }

  .chatbot-minimize {
    width: 36px;
    height: 36px;
    border-radius: 12px;
    background: transparent;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .chatbot-minimize:hover {
    background: var(--color-bg-alt);
    color: var(--color-text);
    transform: scale(1.05);
  }

  .chatbot-welcome {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 1.5rem 1.25rem;
    text-align: center;
    overflow-y: auto;
  }

  .chatbot-welcome.hidden {
    display: none !important;
  }

  .welcome-header {
    margin-bottom: 1.5rem;
  }

  .welcome-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(240, 147, 251, 0.1));
    border-radius: 16px;
    animation: pulse-icon 3s ease-in-out infinite;
  }

  @keyframes pulse-icon {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  .welcome-header h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--color-text);
  }

  .welcome-header p {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    margin: 0;
  }

  .welcome-form {
    width: 100%;
    max-width: 100%;
    padding: 0 0.5rem;
  }

  .welcome-form .form-group {
    margin-bottom: 0.75rem;
  }

  .welcome-form input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: 10px;
    font-size: 0.875rem;
    font-family: var(--font-sans);
    transition: all 0.3s ease;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .welcome-form input:focus {
    outline: none;
    border-color: #667eea;
    background: var(--color-surface);
    box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
  }

  .welcome-form input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .start-chat-btn {
    width: 100%;
    padding: 0.875rem 1.25rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 0.925rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
  }

  .start-chat-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
  }

  .start-chat-btn:active {
    transform: translateY(0);
  }

  .chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .chatbot-messages::-webkit-scrollbar {
    width: 6px;
  }

  .chatbot-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chatbot-messages::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 3px;
  }

  .chatbot-messages::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted);
  }

  .message {
    display: flex;
    gap: 0.75rem;
    max-width: 80%;
    animation: slide-in 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    margin-bottom: 0.25rem;
  }

  @keyframes slide-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Bot messages - LEFT SIDE with fade-in from left */
  .bot-message {
    align-self: flex-start;
    margin-right: auto;
  }

  @keyframes slide-in-left {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .bot-message {
    animation: slide-in-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* User messages - RIGHT SIDE with fade-in from right */
  .user-message {
    align-self: flex-end;
    flex-direction: row-reverse;
    margin-left: auto;
  }

  @keyframes slide-in-right {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .user-message {
    animation: slide-in-right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .message-avatar {
    width: 36px;
    height: 36px;

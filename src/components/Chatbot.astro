  }

  .message-content p {
    margin: 0;
    color: inherit;
  }

  .typing-indicator {
    display: flex;
    gap: 0.35rem;
    padding: 1rem 1.25rem;
  }

  .typing-indicator span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea, #764ba2);
    animation: typing 1.4s infinite ease-in-out;
  }

  .typing-indicator span:nth-child(2) {
    animation-delay: 0.2s;
  }

  .typing-indicator span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes typing {
    0%, 60%, 100% {
      transform: translateY(0);
      opacity: 0.6;
    }
    30% {
      transform: translateY(-12px);
      opacity: 1;
    }
  }

  .quick-replies {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.75rem;
  }

  .quick-reply {
    padding: 0.875rem 1.125rem;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: left;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.625rem;
    position: relative;
    overflow: hidden;
  }

  .quick-reply::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .quick-reply svg {
    flex-shrink: 0;
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  .quick-reply:hover {
    border-color: #667eea;
    color: #667eea;
    transform: translateX(4px);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
  }

  .quick-reply:hover::before {
    opacity: 1;
  }

  .quick-reply:hover svg {
    opacity: 1;
    transform: scale(1.1);
  }

  .chatbot-input {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: 0.75rem;
    background: var(--color-surface);
  }

  .chatbot-input input {
    flex: 1;
    padding: 0.875rem 1.25rem;
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.95rem;
    font-family: var(--font-sans);
    transition: all 0.3s ease;
  }

  .chatbot-input input:focus {
    outline: none;
    border-color: #667eea;
    background: var(--color-surface);
    box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
  }

  .chatbot-input input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .chatbot-input button {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    position: relative;
    overflow: hidden;
  }

  .chatbot-input button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #764ba2 0%, #f093fb 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .chatbot-input button svg {
    position: relative;
    z-index: 1;
  }

  .chatbot-input button:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
  }

  .chatbot-input button:hover::before {
    opacity: 1;
  }

  .chatbot-input button:active {
    transform: translateY(0) scale(0.98);
  }

  .chatbot-actions {
    padding: 0.75rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .export-btn {
    flex: 1;
    min-width: 80px;
    padding: 0.625rem 0.875rem;
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-sans);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .export-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .export-btn svg {
    position: relative;
    flex-shrink: 0;
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  .export-btn:hover {
    border-color: #667eea;
    color: #667eea;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
  }

  .export-btn:hover::before {
    opacity: 1;
  }

  .export-btn:hover svg {
    opacity: 1;
    transform: scale(1.1);
  }

  .export-btn:active {
    transform: translateY(0);
  }

  #export-whatsapp svg {
    fill: #25D366;
  }

  #export-telegram svg {
    fill: #0088cc;
  }

  .chatbot-footer {
    padding: 0.875rem;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.02), rgba(118, 75, 162, 0.02));
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .chatbot-footer svg {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .chatbot-window {
      width: calc(100vw - 3rem);
      max-width: 400px;
      bottom: 80px;
      right: 0;
      left: 50%;
      transform: translateX(-50%) translateY(30px) scale(0.9);
    }

    .chatbot-window.active {
      transform: translateX(-50%) translateY(0) scale(1);
    }
  }

  @media (max-width: 768px) {
    .chatbot-label {
      font-size: 0.8125rem;
      padding: 0.5rem 0.875rem;
      right: 78px;
    }
  }

  @media (max-width: 480px) {
    .chatbot-container {
      bottom: 1rem;
      right: 1rem;
    }

    .chatbot-toggle {
      width: 60px;
      height: 60px;
    }

    .chatbot-label {
      font-size: 0.75rem;
      padding: 0.5rem 0.75rem;
      right: 70px;
    }

    .chatbot-label::after {
      width: 10px;
      height: 10px;
      right: -5px;
    }

    .chatbot-circle-text {
      width: 140px;
      height: 140px;
      top: -40px;
      left: -40px;
    }

    .circle-text {
      font-size: 12px;
      letter-spacing: 2.5px;
    }

    .chatbot-window {
      width: calc(100vw - 2rem);
      height: calc(100vh - 140px);
      max-height: calc(100vh - 140px);
      max-width: 400px;
      border-radius: 20px;
      bottom: 75px;
    }

    .chatbot-header {
      padding: 1rem 1.25rem;
    }

    .chatbot-messages {
      padding: 1rem;
    }

    .chatbot-input {
      padding: 1rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .chatbot-toggle-inner,
    .chatbot-glow,
    .avatar-glow,
    .status-dot,
    .typing-indicator span,
    .message,
    .chatbot-badge {
      animation: none;
    }

    .chatbot-window,
    .chatbot-toggle,
    .quick-reply,
    .chatbot-input button {
      transition: none;
    }
  }
</style>

<script>
  import { sanitizeHTML, escapeHTML } from '@/utils/sanitize';

  let chatHistory: Array<{ role: 'user' | 'assistant'; content: string }> = [];
  let userInfo = { name: '', email: '' };
  let chatStarted = false;

  function initChatbot() {
    const toggle = document.getElementById('chatbot-toggle');
    const window = document.getElementById('chatbot-window');
    const form = document.getElementById('chatbot-form') as HTMLFormElement;
    const input = document.getElementById('chatbot-message') as HTMLInputElement;
    const messages = document.getElementById('chatbot-messages');
    const badge = document.querySelector('.chatbot-badge');
    const minimize = document.querySelector('.chatbot-minimize');
    const welcomeForm = document.getElementById('welcome-form') as HTMLFormElement;
    const welcomeScreen = document.getElementById('chatbot-welcome');
    const userNameInput = document.getElementById('user-name') as HTMLInputElement;
    const userEmailInput = document.getElementById('user-email') as HTMLInputElement;

    // Check all required elements exist
    if (!toggle || !window || !form || !input || !messages || !welcomeForm || !welcomeScreen || !userNameInput) {
      console.error('Chatbot: Required elements not found');
      return;
    }

    // Handle welcome form submission
    welcomeForm.addEventListener('submit', (e) => {
      e.preventDefault();
      userInfo.name = userNameInput.value.trim();
      userInfo.email = userEmailInput.value.trim();
      chatStarted = true;

      // Hide welcome screen and show chat
      welcomeScreen.classList.add('hidden');
      messages.style.display = 'flex';
      form.style.display = 'flex';

      // Show export buttons
      const actionsContainer = document.getElementById('chatbot-actions');
      if (actionsContainer) {
        actionsContainer.style.display = 'flex';
      }

      // Add welcome message from bot
      setTimeout(() => {
        addMessage(`Hi ${userInfo.name}! 👋 I'm Kodie, your AI assistant at Hodges & Co. I can help with web development, WordPress, SEO, performance optimization, and technical questions. What would you like to know?`, 'bot');
      }, 300);

      // Focus on input
      input.focus();
    });

    // Toggle chatbot
    toggle.addEventListener('click', () => {
      toggle.classList.toggle('active');
      window.classList.toggle('active');
      badge?.classList.add('hidden');

      if (window.classList.contains('active')) {
        // Only focus input if chat has started
        if (chatStarted) {
          input.focus();
        }
      }
    });

    // Minimize button
    minimize?.addEventListener('click', () => {
      toggle.classList.remove('active');
      window.classList.remove('active');
    });

    // Handle form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!chatStarted) {
        return; // Don't allow messages before user info is collected
      }

      const message = input.value.trim();
      if (!message) return;

      // Add user message to chat
      addMessage(message, 'user');
      chatHistory.push({ role: 'user', content: message });
      input.value = '';

      // Show typing indicator with realistic delay
      const typingId = showTypingIndicator();

      try {
        // Send to API with user info - Using Gemini 2.5 Flash AI
        const response = await fetch('/api/chat/kodie', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message,
            conversation_history: chatHistory.slice(0, -1), // Don't include current message
            userName: userInfo.name,
            userEmail: userInfo.email || 'Not provided',
          }),
        });

        const data = await response.json();

        // Extract the AI response message
        const aiMessage = data.response?.message || data.response;

        // Add realistic typing delay based on response length
        const responseLength = aiMessage?.length || 100;
        const typingDelay = Math.min(800 + (responseLength * 15), 3000); // 800ms to 3s
        await new Promise(resolve => setTimeout(resolve, typingDelay));

        // Remove typing indicator
        removeTypingIndicator(typingId);

        if (data.success && aiMessage) {
          addMessage(aiMessage, 'bot');
          chatHistory.push({ role: 'assistant', content: aiMessage });
        } else {
          console.error('Chat API error:', data);
          const errorMsg = data.details || data.error || 'Sorry, I encountered an error. Please try again.';
          addMessage(errorMsg, 'bot');

          // Log debug info
          if (data.debug) {
            console.log('Debug info:', data.debug);
          }
        }
      } catch (error) {
        console.error('Chat fetch error:', error);
        removeTypingIndicator(typingId);
        addMessage('Sorry, I encountered an error connecting to the server. Please try again.', 'bot');
      }
    });

    function addMessage(content: string, type: 'user' | 'bot') {
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${type === 'user' ? 'user-message' : 'bot-message'}`;

      // Force positioning with inline styles to override any cache
      if (type === 'user') {
        messageDiv.style.alignSelf = 'flex-end';
        messageDiv.style.flexDirection = 'row-reverse';
        messageDiv.style.marginLeft = 'auto';
        messageDiv.style.marginRight = '0';
      } else {
        messageDiv.style.alignSelf = 'flex-start';
        messageDiv.style.marginRight = 'auto';
        messageDiv.style.marginLeft = '0';
      }

      const avatarIcon = type === 'bot'
        ? `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="currentColor" opacity="0.9"/>
            <path d="M2 17L12 22L22 17M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="7" r="2" fill="white"/>
          </svg>`
        : `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>`;

      // Force colors with inline styles
      const contentStyle = type === 'user'
        ? 'background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%); color: white; border-bottom-right-radius: 6px; box-shadow: 0 4px 20px rgba(99, 102, 241, 0.45); border: 1px solid rgba(255, 255, 255, 0.2);'
        : 'background: white; color: #1f2937; border-bottom-left-radius: 6px; border: 2px solid rgba(102, 126, 234, 0.15); box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);';

      // Sanitize user/bot message content to prevent XSS
      messageDiv.innerHTML = `
        <div class="message-avatar">
          ${avatarIcon}
        </div>
        <div class="message-content" style="${contentStyle}">
          <p style="margin: 0; color: inherit;">${sanitizeHTML(content)}</p>
        </div>
      `;

      messages?.appendChild(messageDiv);
      messages!.scrollTop = messages!.scrollHeight;
    }

    function showTypingIndicator(): string {
      const id = 'typing-' + Date.now();
      const typingDiv = document.createElement('div');
      typingDiv.id = id;
      typingDiv.className = 'message bot-message';
      // Static HTML - safe (no user content)
      typingDiv.innerHTML = `
        <div class="message-avatar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="currentColor" opacity="0.9"/>
            <path d="M2 17L12 22L22 17M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="7" r="2" fill="white"/>
          </svg>
        </div>
        <div class="message-content typing-indicator">
          <span></span><span></span><span></span>
        </div>
      `;

      messages?.appendChild(typingDiv);
      messages!.scrollTop = messages!.scrollHeight;
      return id;
    }

    function removeTypingIndicator(id: string) {
      document.getElementById(id)?.remove();
    }
  }

  // Lazy load chatbot: only initialize when user opens it
  let chatbotInitialized = false;

  function lazyInitChatbot() {
    if (!chatbotInitialized) {
      chatbotInitialized = true;
      initChatbot();
    }
  }

  // Export Functions
  function formatConversationTranscript(): string {
    const date = new Date().toLocaleString();
    let transcript = `Chat Conversation with Kodie AI Assistant\n`;
    transcript += `Date: ${date}\n`;
    transcript += `User: ${userInfo.name} ${userInfo.email ? `(${userInfo.email})` : ''}\n`;
    transcript += `\n${'='.repeat(50)}\n\n`;

    chatHistory.forEach((msg, index) => {
      const speaker = msg.role === 'user' ? userInfo.name : 'Kodie';
      transcript += `${speaker}: ${msg.content}\n\n`;
    });

    transcript += `${'='.repeat(50)}\n`;
    transcript += `\nPowered by OHWP Studios | ohwpstudios.org\n`;

    return transcript;
  }

  function setupExportButtons() {
    const actionsContainer = document.getElementById('chatbot-actions');
    const whatsappBtn = document.getElementById('export-whatsapp');
    const telegramBtn = document.getElementById('export-telegram');
    const emailBtn = document.getElementById('export-email');
    const copyBtn = document.getElementById('export-copy');

    // WhatsApp Export
    whatsappBtn?.addEventListener('click', () => {
      if (chatHistory.length === 0) {
        alert('No conversation to export yet. Start chatting first!');
        return;
      }
      const transcript = formatConversationTranscript();
      const text = encodeURIComponent(transcript);
      // WhatsApp Web/App link with pre-filled text
      const whatsappUrl = `https://wa.me/?text=${text}`;
      window.open(whatsappUrl, '_blank');
    });

    // Telegram Export
    telegramBtn?.addEventListener('click', () => {
      if (chatHistory.length === 0) {
        alert('No conversation to export yet. Start chatting first!');
        return;
      }
      const transcript = formatConversationTranscript();
      const text = encodeURIComponent(transcript);
      // Telegram share link
      const telegramUrl = `https://t.me/share/url?url=${encodeURIComponent('https://ohwpstudios.org')}&text=${text}`;
      window.open(telegramUrl, '_blank');
    });

    // Email Export
    emailBtn?.addEventListener('click', () => {
      if (chatHistory.length === 0) {
        alert('No conversation to export yet. Start chatting first!');
        return;
      }
      const transcript = formatConversationTranscript();
      const subject = encodeURIComponent('Chat Conversation Transcript - OHWP Studios');
      const body = encodeURIComponent(transcript);
      const mailtoUrl = `mailto:?subject=${subject}&body=${body}`;
      window.location.href = mailtoUrl;
    });

    // Copy to Clipboard
    copyBtn?.addEventListener('click', async () => {
      if (chatHistory.length === 0) {
        alert('No conversation to export yet. Start chatting first!');
        return;
      }
      const transcript = formatConversationTranscript();
      try {
        await navigator.clipboard.writeText(transcript);
        const originalText = copyBtn.innerHTML;
        copyBtn.innerHTML = `
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Copied!
        `;
        copyBtn.style.borderColor = '#10b981';
        copyBtn.style.color = '#10b981';
        setTimeout(() => {
          copyBtn.innerHTML = originalText;
          copyBtn.style.borderColor = '';
          copyBtn.style.color = '';
        }, 2000);
      } catch (error) {
        console.error('Failed to copy:', error);
        alert('Failed to copy to clipboard. Please try again.');
      }
    });

    // Show export buttons when chat starts
    if (chatStarted && actionsContainer) {
      actionsContainer.style.display = 'flex';
    }
  }

  // Initialize on first toggle click
  const toggle = document.getElementById('chatbot-toggle');
  toggle?.addEventListener('click', lazyInitChatbot, { once: true });

  // Setup export buttons on page load
  setupExportButtons();

  // Reinitialize on Astro page transitions (if already initialized)
  document.addEventListener('astro:page-load', () => {
    if (chatbotInitialized) {
      initChatbot();
      setupExportButtons();
    } else {
      // Re-attach listener for new page
      const newToggle = document.getElementById('chatbot-toggle');
      newToggle?.addEventListener('click', lazyInitChatbot, { once: true });
      setupExportButtons();
    }
  });
</script>

---
// Homepage FAQ — answer-first content + FAQPage JSON-LD for AEO/GEO and rich results.
// Answers are written to stand alone (each is independently citable by AI answer engines).
import AdinkraIcon from '@/components/AdinkraIcon.astro';
const faqs = [
  {
    question: 'What does OhWP Studios do?',
    answer:
      'OhWP Studios is a fullstack software development studio that builds custom web applications, SaaS products, APIs, and AI-powered software for organisations across Ghana and Africa. We engineer the whole stack — frontend, backend, APIs, databases, and cloud infrastructure — as one accountable team, using React, Next.js, Node.js, TypeScript, and Python on the Cloudflare edge and AWS.'
  },
  {
    question: 'Who does OhWP Studios build software for?',
    answer:
      'We build for organisations across Ghana and the wider African market, with deep focus on government and civic technology, fintech, education technology, and healthcare. Our clients range from startups needing a first MVP to established institutions launching digital services for mobile-heavy, bandwidth-constrained users.'
  },
  {
    question: 'How much does a project cost?',
    answer:
      'Projects are quoted in Ghana Cedis (GH₵) with a US Dollar reference shown alongside, and the final figure depends on scope. You can get an instant, AI-assisted estimate in a few minutes using our project estimator, then refine it with us on a discovery call.'
  },
  {
    question: 'Which technologies does OhWP Studios use?',
    answer:
      'We build with React, Next.js, Astro, and Vue on the frontend; Node.js, TypeScript, Python, and Hono on the backend; PostgreSQL, D1, and Redis for data; and deploy on Cloudflare, AWS, and Vercel. We integrate AI — including large language models and retrieval-augmented generation — where it solves a real problem, choosing the right tool for each project.'
  },
  {
    question: 'How do I start a project with OhWP Studios?',
    answer:
      'The fastest way is to use our AI-assisted project estimator, which scopes your idea and returns a cost estimate in GH₵ (with a USD reference). From there we refine the scope on a free discovery call. You can also reach us directly at ohwpstudios@gmail.com.'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer
    }
  }))
};
---

<section class="home-faq" aria-labelledby="home-faq-title">
  <div class="container">
    <span class="title-adinkra adinkra-primary" aria-hidden="true">
      <AdinkraIcon symbol="nea-onnim" size={28} />
    </span>
    <h2 id="home-faq-title" class="home-faq-title">Frequently Asked Questions</h2>
    <p class="home-faq-intro">
      OhWP Studios is a fullstack software development studio building web apps, SaaS, APIs, and
      AI-powered products for Ghana and Africa. Here are quick answers to the questions we hear most.
    </p>

    <div class="home-faq-list">
      {faqs.map((faq, i) => (
        <details class="home-faq-item" open={i === 0}>
          <summary class="home-faq-q">{faq.question}</summary>
          <div class="home-faq-a">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <p class="home-faq-cta">
      Ready to scope your project? <a href="/estimate-project">Get an instant AI estimate</a>.
      More questions? <a href="/contact">Ask us &rarr;</a>
    </p>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .home-faq {
    /* Match the bumped .section rhythm (7.5rem desktop / 3.5rem <=768px) */
    padding: 7.5rem 0;
  }

  @media (max-width: 768px) {
    .home-faq {
      padding: 3.5rem 0;
    }
  }

  .title-adinkra {
    display: flex;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
    margin-bottom: var(--spacing-sm, 0.75rem);
  }

  .home-faq-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: var(--spacing-md);
  }

  .home-faq-intro {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--spacing-2xl);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .home-faq-list {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .home-faq-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.02);
    overflow: hidden;
  }

  .home-faq-q {
    cursor: pointer;
    list-style: none;
    padding: var(--spacing-lg);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
  }

  .home-faq-q::-webkit-details-marker {
    display: none;
  }

  .home-faq-q::after {
    content: '+';
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-primary);
    transition: transform var(--transition-base);
  }

  .home-faq-item[open] .home-faq-q::after {
    transform: rotate(45deg);
  }

  .home-faq-a {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .home-faq-cta {
    text-align: center;
    margin-top: var(--spacing-2xl);
    color: var(--color-text-muted);
  }

  .home-faq-cta a {
    color: var(--color-primary);
    font-weight: 600;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-faq-q::after {
      transition: none;
    }
  }
</style>

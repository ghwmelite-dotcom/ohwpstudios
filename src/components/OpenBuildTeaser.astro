---
// Slim homepage teaser that drives discovery to the /open-build gateway.
---
<section class="obt-section" data-animate>
  <div class="container">
    <a href="/open-build" class="obt-band">
      <div class="obt-grid" aria-hidden="true"></div>

      <div class="obt-main">
        <span class="obt-live">
          <span class="obt-live-dot"></span>
          LIVE · OPEN BUILD
        </span>
        <h2 class="obt-title">We build real solutions — <span class="obt-accent">live, in public.</span></h2>
        <p class="obt-sub">
          The community names a real Ghanaian problem, we build it on stream with Claude Code,
          ship a beginner guide, and you vote on what’s built next.
        </p>
        <span class="obt-meta">Season 1 · 5 builds in the slate</span>
      </div>

      <span class="obt-cta">
        Explore Open Build
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  .obt-section { padding: 1rem 0 3rem; }

  .obt-band {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.25rem 2.5rem;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    text-decoration: none;
    background:
      radial-gradient(ellipse 60% 120% at 0% 0%, rgba(227, 169, 43, 0.16), transparent 60%),
      radial-gradient(ellipse 50% 120% at 100% 100%, rgba(245, 158, 11, 0.12), transparent 60%),
      var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .obt-band:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl, var(--shadow-lg));
    border-color: var(--color-primary);
  }

  .obt-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 80% 100% at 50% 50%, #000 10%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 50%, #000 10%, transparent 70%);
    opacity: 0.35;
    pointer-events: none;
  }

  .obt-main { position: relative; z-index: 1; max-width: 640px; }

  .obt-live {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.25);
    color: #ef4444;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }
  .obt-live-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #ef4444;
    animation: obt-ping 1.8s ease-out infinite;
  }

  .obt-title {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 0.6rem;
    color: var(--color-text);
  }
  .obt-accent {
    background: var(--gradient-primary);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .obt-sub {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }
  .obt-meta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    opacity: 0.85;
  }

  .obt-cta {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 48px;
    padding: 0.9rem 1.6rem;
    border-radius: var(--radius-lg);
    background: var(--gradient-primary);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    white-space: nowrap;
    box-shadow: 0 8px 22px rgba(227, 169, 43, 0.3);
    transition: gap 0.25s ease;
  }
  .obt-band:hover .obt-cta { gap: 1rem; }

  @keyframes obt-ping {
    0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.5); }
    70% { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); }
    100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .obt-live-dot { animation: none; }
    .obt-band:hover { transform: none; }
  }

  @media (max-width: 860px) {
    .obt-band {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 2rem 1.5rem;
    }
    .obt-cta { width: 100%; justify-content: center; }
  }
</style>

---
interface Props {
  type: 'organization' | 'website' | 'article' | 'breadcrumb' | 'service';
  data?: any;
}

const { type, data } = Astro.props;
const siteUrl = Astro.url.origin;

// Organization Schema
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "OhWP Studios",
  "alternateName": "OHWP Studios",
  "url": siteUrl,
  "logo": `${siteUrl}/icons/icon-512x512.png`,
  "description": "OhWP Studios is a fullstack software development studio building web apps, SaaS, APIs and AI-powered products for organisations across Ghana and Africa.",
  "email": "ohwpstudios@gmail.com",
  "parentOrganization": {
    "@type": "Organization",
    "name": "Hodges & Co."
  },
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "GH"
  },
  "areaServed": [
    { "@type": "Country", "name": "Ghana" },
    { "@type": "Place", "name": "Africa" }
  ],
  "knowsAbout": [
    "Fullstack software development",
    "React development",
    "Next.js development",
    "Node.js development",
    "Python development",
    "Custom web application development",
    "SaaS development",
    "API development",
    "AI-powered applications",
    "Startup MVP development"
  ],
  "sameAs": [
    "https://twitter.com/ohwpstudios",
    "https://linkedin.com/company/ohwpstudios",
    "https://github.com/ohwpstudios",
    "https://instagram.com/ohwpstudios"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": "ohwpstudios@gmail.com",
    "areaServed": "GH",
    "availableLanguage": ["en"]
  }
};

// Website Schema (no SearchAction: site search is client-side only, no query-string endpoint exists)
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "OhWP Studios",
  "url": siteUrl,
  "description": "Fullstack software development studio for Ghana and Africa.",
  "publisher": {
    "@type": "Organization",
    "name": "OhWP Studios",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/icons/icon-512x512.png`
    }
  }
};

// Article Schema (for blog posts)
const articleSchema = data ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": data.title,
  "description": data.excerpt || data.seo_description,
  "image": data.featured_image || `${siteUrl}/og-image.jpg`,
  "author": {
    "@type": "Person",
    "name": data.author || "OhWP Studios"
  },
  "publisher": {
    "@type": "Organization",
    "name": "OhWP Studios",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/icons/icon-512x512.png`
    }
  },
  "datePublished": data.published_at,
  "dateModified": data.updated_at || data.published_at,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${data.slug}`
  },
  "keywords": data.tags
} : null;

// BreadcrumbList Schema
const breadcrumbSchema = data?.breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": data.breadcrumbs.map((crumb: any, index: number) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": crumb.name,
    "item": `${siteUrl}${crumb.path}`
  }))
} : null;

// Service Schema
const serviceSchema = data ? {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": data.name,
  "description": data.description,
  "provider": {
    "@type": "Organization",
    "name": "OhWP Studios"
  },
  "serviceType": data.type || "Software Development",
  "areaServed": [
    { "@type": "Country", "name": "Ghana" },
    { "@type": "Place", "name": "Africa" }
  ]
} : null;

let schema;
switch (type) {
  case 'organization':
    schema = organizationSchema;
    break;
  case 'website':
    schema = websiteSchema;
    break;
  case 'article':
    schema = articleSchema;
    break;
  case 'breadcrumb':
    schema = breadcrumbSchema;
    break;
  case 'service':
    schema = serviceSchema;
    break;
}
---

{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}

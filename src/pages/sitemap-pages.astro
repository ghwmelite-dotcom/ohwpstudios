---
import SEOPageLayout from '../layouts/SEOPageLayout.astro';

const services = [
  { title: 'Custom Web Application Development', url: '/services/custom-web-application-development' },
  { title: 'SaaS Application Development', url: '/services/saas-application-development' },
  { title: 'API Development Services', url: '/services/api-development-services' }
];

const technologies = [
  { title: 'Fullstack Development', url: '/technologies/fullstack-development' },
  { title: 'React Development', url: '/technologies/react-development' },
  { title: 'Next.js Development', url: '/technologies/nextjs-development' },
  { title: 'Node.js Development', url: '/technologies/nodejs-development' },
  { title: 'Python Development', url: '/technologies/python-development' }
];

const industries = [
  { title: 'Fintech Software Development', url: '/industries/fintech-software-development' },
  { title: 'Healthcare Software Development', url: '/industries/healthcare-software-development' },
  { title: 'Education Software Development', url: '/industries/education-software-development' }
];

const solutions = [
  { title: 'AI-Powered Application Development', url: '/solutions/ai-powered-application-development' },
  { title: 'Startup MVP Development', url: '/solutions/startup-mvp-development' }
];
---

<SEOPageLayout
  title="Services & Solutions Sitemap | OHWP Studios"
  description="Explore our comprehensive range of web and mobile development services, technologies, industry solutions, and custom software development offerings."
  keywords="web development services, mobile app development, custom software, technology services, industry solutions"
  h1="Services & Solutions"
  heroTitle="Comprehensive Web & Mobile Development Services"
  heroSubtitle="Browse our complete range of services, technologies, industry expertise, and custom solutions."
>
  <section class="sitemap-section">
    <div class="container">

      <!-- Services -->
      <div class="sitemap-category" data-animate>
        <h2 class="category-title">Our Services</h2>
        <p class="category-description">
          Professional development services for web, mobile, and custom applications
        </p>
        <div class="links-grid">
          {services.map((item) => (
            <a href={item.url} class="sitemap-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
              {item.title}
            </a>
          ))}
        </div>
      </div>

      <!-- Technologies -->
      <div class="sitemap-category" data-animate>
        <h2 class="category-title">Technologies We Use</h2>
        <p class="category-description">
          Expert development with modern frameworks and programming languages
        </p>
        <div class="links-grid">
          {technologies.map((item) => (
            <a href={item.url} class="sitemap-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
              {item.title}
            </a>
          ))}
        </div>
      </div>

      <!-- Industries -->
      <div class="sitemap-category" data-animate>
        <h2 class="category-title">Industry Expertise</h2>
        <p class="category-description">
          Specialized software solutions for various industries and verticals
        </p>
        <div class="links-grid">
          {industries.map((item) => (
            <a href={item.url} class="sitemap-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
              {item.title}
            </a>
          ))}
        </div>
      </div>

      <!-- Solutions -->
      <div class="sitemap-category" data-animate>
        <h2 class="category-title">Custom Solutions</h2>
        <p class="category-description">
          Tailored solutions for startups, enterprises, and specific business needs
        </p>
        <div class="links-grid">
          {solutions.map((item) => (
            <a href={item.url} class="sitemap-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
              {item.title}
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>
</SEOPageLayout>

<style>
  .sitemap-section {
    padding: var(--spacing-3xl) 0;
  }

  .sitemap-category {
    margin-bottom: var(--spacing-3xl);
    padding-bottom: var(--spacing-3xl);
    border-bottom: 1px solid var(--color-border);
    opacity: 0;
    transition: opacity 0.6s ease-out;
  }

  .sitemap-category:last-child {
    border-bottom: none;
  }

  .sitemap-category.animate-in {
    opacity: 1;
    animation: fade-in 0.6s ease-out forwards;
  }

  .category-title {
    font-size: 2rem;
    margin-bottom: var(--spacing-sm);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .category-description {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-xl);
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-md);
  }

  .sitemap-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .sitemap-link svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .sitemap-link:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: var(--color-primary);
    transform: translateX(5px);
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .links-grid {
      grid-template-columns: 1fr;
    }

    .category-title {
      font-size: 1.5rem;
    }
  }
</style>

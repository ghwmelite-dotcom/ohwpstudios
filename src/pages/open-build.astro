---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

const HUB = 'https://open-build.ohwpstudios.org';
const REPO = 'https://github.com/ghwmelite-dotcom/open-build';

const steps = [
  { n: '01', title: 'Name a problem', body: 'The community names a real Ghanaian problem worth solving — civic or everyday.' },
  { n: '02', title: 'Scope it small', body: 'We cut it down to one shippable idea. Small enough to finish in a session.' },
  { n: '03', title: 'Build it live', body: 'We build it on stream with Claude Code — real decisions, real debugging, no edited magic.' },
  { n: '04', title: 'Ship a guide', body: 'A beginner-friendly walkthrough so anyone can rebuild it — even on the free Claude.ai tier.' },
  { n: '05', title: 'Vote what’s next', body: 'The community votes on the next build. Your fingerprint is on the outcome.' },
];

const values = [
  { icon: 'M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 0v20M2 12h20', title: 'Ghana-rooted', body: 'Every build is a civic or everyday tool for a real local problem — not generic coding content.' },
  { icon: 'M13 2L3 14h7l-1 8 10-12h-7l1-8z', title: 'Built live with Claude Code', body: 'No post-production polish. You watch the real decisions, mistakes, and fixes happen.' },
  { icon: 'M16 18l2 2 4-4M4 16l4.586-4.586a2 2 0 0 1 2.828 0L16 16m-2-2l1.586-1.586a2 2 0 0 1 2.828 0L20 14M6 20h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z', title: 'Yours to rebuild', body: 'Single-file, copy-pasteable apps you can recreate from one prompt. No build step, no dependencies.' },
  { icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75', title: 'Community-voted', body: 'You name the problems and vote on what gets built next. Every ballot option is already green-lit.' },
];

const builds = [
  { id: '001', name: 'Accra Flood-Risk Map', cat: 'Civic', tag: 'civic', what: 'Flood-prone areas surfaced from elevation data.', single: false, kind: 'Python', note: 'Prototype — not an official warning. Follow GMet / NADMO.' },
  { id: '002', name: 'Which Trotro?', cat: 'Everyday', tag: 'everyday', what: 'Start + destination → route and approximate fare.', single: true, kind: 'Single-file', note: 'Fares are community-maintained — confirm with the mate.' },
  { id: '003', name: 'MoMo Fee Calculator', cat: 'Money', tag: 'money', what: 'Enter an amount → the fee and what actually lands.', single: true, kind: 'Single-file', note: 'Fees vary by network — check official rates.' },
  { id: '004', name: 'NSMQ / BECE Quiz Trainer', cat: 'Education', tag: 'education', what: 'Drill past questions and track your score.', single: true, kind: 'Single-file', note: 'A study aid — cross-check official syllabi.' },
  { id: '005', name: 'Galamsey Watch', cat: 'Civic', tag: 'civic', what: 'Map galamsey impact from public data.', single: false, kind: 'Map / data', note: 'Awareness only — never accuse individuals. Public data only.' },
];
---

<BaseLayout title="Open Build | Real problems, built live — OhWP Studios" description="Open Build by OhWP Studios: a livestream show where the community names a real Ghanaian problem, we build it live with Claude Code, ship a beginner guide, and you vote on what's built next.">
  <Header />
  <main class="ob">
    <!-- ===== Hero ===== -->
    <section class="ob-hero">
      <div class="ob-grid-bg" aria-hidden="true"></div>
      <div class="container ob-hero-inner">
        <span class="ob-live">
          <span class="ob-live-dot"></span>
          LIVE · BUILD IN PUBLIC
        </span>
        <h1 class="ob-title">Open<span class="ob-title-accent">Build</span></h1>
        <p class="ob-tagline">Real problems, built live,<br/><em>simple enough to build yourself.</em></p>
        <p class="ob-sub">
          A livestream show by OhWP Studios: the community names a real Ghanaian problem,
          we build it live with Claude Code, ship a beginner guide so anyone can rebuild it,
          then you vote on what gets built next.
        </p>
        <div class="ob-cta-row">
          <a class="ob-btn ob-btn-primary" href={HUB} target="_blank" rel="noopener noreferrer">
            <span class="ob-btn-pulse"></span>
            Watch &amp; Vote at the Hub
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
          <a class="ob-btn ob-btn-ghost" href={`${HUB}/#suggest`} target="_blank" rel="noopener noreferrer">Suggest a Problem</a>
        </div>
        <div class="ob-meta">
          <span><strong>Season 1</strong> · 5 builds in the slate</span>
          <span class="ob-meta-sep">·</span>
          <span>Working title: <em>Nnoboa</em> — the Akan tradition of communal help</span>
        </div>
      </div>
    </section>

    <!-- ===== The promise ===== -->
    <section class="ob-section container">
      <div class="ob-values">
        {values.map((v) => (
          <article class="ob-value">
            <div class="ob-value-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={`<path d="${v.icon}"/>`}></svg>
            </div>
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== The loop ===== -->
    <section class="ob-section container">
      <header class="ob-head">
        <span class="ob-kicker">The Loop</span>
        <h2>How the show works</h2>
        <p>Five steps, on repeat. Each turn deepens investment — because the viewer's fingerprint is on the outcome.</p>
      </header>
      <ol class="ob-steps">
        {steps.map((s) => (
          <li class="ob-step">
            <span class="ob-step-n">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </li>
        ))}
      </ol>
    </section>

    <!-- ===== Build slate ===== -->
    <section class="ob-section container">
      <header class="ob-head">
        <span class="ob-kicker">Season 1 · The Slate</span>
        <h2>What we’re building</h2>
        <p>Five pre-scoped, green-lit briefs. Sequenced to vary the feeling of each episode &mdash; civic, everyday, money, education.</p>
      </header>
      <div class="ob-builds">
        {builds.map((b) => (
          <article class={`ob-build ob-cat-${b.tag}`}>
            <div class="ob-build-top">
              <span class="ob-build-id">#{b.id}</span>
              <span class="ob-build-cat">{b.cat}</span>
            </div>
            <h3 class="ob-build-name">{b.name}</h3>
            <p class="ob-build-what">{b.what}</p>
            <div class="ob-build-foot">
              <span class={`ob-chip ${b.single ? 'ob-chip-yes' : 'ob-chip-no'}`}>
                {b.single ? '✓ ' : ''}{b.kind}
              </span>
              <span class="ob-build-status">In the slate</span>
            </div>
            <p class="ob-build-note">{b.note}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== Positioning band ===== -->
    <section class="ob-band">
      <div class="container ob-band-inner">
        <h2>Most agencies show you a portfolio.<br/><span class="ob-band-accent">We build in front of you.</span></h2>
        <p>
          Open Build is OhWP Studios working in the open — the same edge-native, AI-assisted approach
          we use for client work, applied to problems our community actually faces. It's our proof,
          our classroom, and our community, all at once.
        </p>
        <div class="ob-cta-row ob-cta-center">
          <a class="ob-btn ob-btn-primary" href={HUB} target="_blank" rel="noopener noreferrer">
            <span class="ob-btn-pulse"></span>
            Watch the next build
          </a>
          <a class="ob-btn ob-btn-ghost" href={REPO} target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11 11 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
            See it on GitHub
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .ob { overflow: hidden; }

  /* ===== Hero ===== */
  .ob-hero {
    position: relative;
    padding: calc(var(--header-height) + 5rem) 0 5rem;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99, 102, 241, 0.18), transparent 60%),
      radial-gradient(ellipse 60% 50% at 85% 20%, rgba(245, 158, 11, 0.12), transparent 60%);
  }
  .ob-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, #000 30%, transparent 75%);
    opacity: 0.5;
    pointer-events: none;
  }
  .ob-hero-inner {
    position: relative;
    text-align: center;
    max-width: 820px;
  }
  .ob-live {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 1rem;
    border-radius: var(--radius-full);
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.25);
    color: #ef4444;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin-bottom: 1.75rem;
    animation: ob-in 0.6s ease both;
  }
  .ob-live-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #ef4444;
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.6);
    animation: ob-ping 1.8s ease-out infinite;
  }
  .ob-title {
    font-size: clamp(3.5rem, 12vw, 7rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0 0 1.25rem;
    color: var(--color-text);
    animation: ob-in 0.7s ease both 0.05s;
  }
  .ob-title-accent {
    background: var(--gradient-primary);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .ob-tagline {
    font-size: clamp(1.35rem, 3.5vw, 2rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    animation: ob-in 0.7s ease both 0.12s;
  }
  .ob-tagline em { font-style: italic; color: var(--color-accent); }
  .ob-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 640px;
    margin: 0 auto 2.25rem;
    animation: ob-in 0.7s ease both 0.18s;
  }
  .ob-cta-row {
    display: flex; flex-wrap: wrap; gap: 0.875rem; justify-content: center;
    animation: ob-in 0.7s ease both 0.24s;
  }
  .ob-cta-center { justify-content: center; margin-top: 2rem; }
  .ob-btn {
    position: relative;
    display: inline-flex; align-items: center; gap: 0.55rem;
    min-height: 48px;
    padding: 0.85rem 1.6rem;
    border-radius: var(--radius-lg);
    font-weight: 700; font-size: 1rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    overflow: hidden;
  }
  .ob-btn-primary {
    background: var(--gradient-primary);
    color: #fff;
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.32);
  }
  .ob-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(99, 102, 241, 0.42); }
  .ob-btn-pulse {
    position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    transform: translateX(-100%);
    animation: ob-sheen 3.5s ease-in-out infinite;
  }
  .ob-btn-ghost {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--color-text);
    backdrop-filter: blur(10px);
  }
  .ob-btn-ghost:hover { transform: translateY(-3px); border-color: var(--color-primary); color: var(--color-primary); }
  .ob-meta {
    margin-top: 2rem;
    display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; align-items: center;
    font-size: 0.9rem; color: var(--color-text-muted);
    animation: ob-in 0.7s ease both 0.3s;
  }
  .ob-meta strong { color: var(--color-text); }
  .ob-meta em { color: var(--color-accent); font-style: normal; font-weight: 600; }
  .ob-meta-sep { opacity: 0.4; }

  /* ===== Sections ===== */
  .ob-section { padding: 4rem 0; }
  .ob-head { text-align: center; max-width: 680px; margin: 0 auto 3rem; }
  .ob-kicker {
    display: inline-block;
    font-size: 0.8rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }
  .ob-head h2 {
    font-size: clamp(2rem, 5vw, 2.75rem); font-weight: 800; letter-spacing: -0.02em;
    margin: 0 0 0.75rem; color: var(--color-text);
  }
  .ob-head p { font-size: 1.05rem; line-height: 1.6; color: var(--color-text-muted); margin: 0; }

  /* ===== Values ===== */
  .ob-values {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem;
  }
  .ob-value {
    padding: 1.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .ob-value:hover { transform: translateY(-5px); border-color: var(--color-primary); box-shadow: var(--shadow-lg); }
  .ob-value-icon {
    width: 48px; height: 48px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    background: var(--gradient-primary); color: #fff;
    margin-bottom: 1rem;
  }
  .ob-value h3 { font-size: 1.15rem; font-weight: 700; margin: 0 0 0.5rem; color: var(--color-text); }
  .ob-value p { font-size: 0.95rem; line-height: 1.6; color: var(--color-text-muted); margin: 0; }

  /* ===== Steps ===== */
  .ob-steps {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.25rem;
    counter-reset: none;
  }
  .ob-step {
    position: relative;
    padding: 1.75rem 1.5rem;
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }
  .ob-step-n {
    font-family: 'Fira Code', ui-monospace, monospace;
    font-size: 2rem; font-weight: 800;
    background: var(--gradient-primary);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    display: block; line-height: 1; margin-bottom: 0.75rem;
  }
  .ob-step h3 { font-size: 1.05rem; font-weight: 700; margin: 0 0 0.4rem; color: var(--color-text); }
  .ob-step p { font-size: 0.9rem; line-height: 1.55; color: var(--color-text-muted); margin: 0; }

  /* ===== Builds ===== */
  .ob-builds {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem;
  }
  .ob-build {
    display: flex; flex-direction: column;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
    border-radius: var(--radius-xl);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .ob-build:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
  .ob-cat-civic { border-top-color: #ef4444; }
  .ob-cat-everyday { border-top-color: #6366f1; }
  .ob-cat-money { border-top-color: #10b981; }
  .ob-cat-education { border-top-color: #f59e0b; }
  .ob-build-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
  .ob-build-id {
    font-family: 'Fira Code', ui-monospace, monospace;
    font-size: 1.05rem; font-weight: 800; color: var(--color-text-muted); letter-spacing: 0.02em;
  }
  .ob-build-cat {
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 0.25rem 0.65rem; border-radius: var(--radius-full);
    background: var(--gradient-card); color: var(--color-primary);
  }
  .ob-cat-civic .ob-build-cat { color: #ef4444; background: rgba(239,68,68,0.1); }
  .ob-cat-money .ob-build-cat { color: #10b981; background: rgba(16,185,129,0.1); }
  .ob-cat-education .ob-build-cat { color: #f59e0b; background: rgba(245,158,11,0.1); }
  .ob-build-name { font-size: 1.2rem; font-weight: 700; margin: 0 0 0.5rem; color: var(--color-text); line-height: 1.25; }
  .ob-build-what { font-size: 0.95rem; line-height: 1.55; color: var(--color-text-muted); margin: 0 0 1rem; flex: 1; }
  .ob-build-foot { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.875rem; }
  .ob-chip {
    font-size: 0.78rem; font-weight: 700; padding: 0.28rem 0.6rem; border-radius: var(--radius-full);
  }
  .ob-chip-yes { background: rgba(16,185,129,0.12); color: #10b981; }
  .ob-chip-no { background: var(--color-bg-alt); color: var(--color-text-muted); border: 1px solid var(--color-border); }
  .ob-build-status { font-size: 0.78rem; font-weight: 700; color: var(--color-text-muted); opacity: 0.8; }
  .ob-build-note {
    font-size: 0.8rem; line-height: 1.5; color: var(--color-text-muted);
    margin: 0; padding-top: 0.875rem; border-top: 1px dashed var(--color-border);
    font-style: italic; opacity: 0.85;
  }

  /* ===== Band ===== */
  .ob-band {
    margin: 2rem 0 0;
    padding: 5rem 0;
    background:
      radial-gradient(ellipse 70% 80% at 50% 0%, rgba(99,102,241,0.12), transparent 60%),
      var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
  }
  .ob-band-inner { text-align: center; max-width: 760px; }
  .ob-band h2 {
    font-size: clamp(1.9rem, 5vw, 3rem); font-weight: 900; letter-spacing: -0.02em;
    line-height: 1.15; margin: 0 0 1.25rem; color: var(--color-text);
  }
  .ob-band-accent {
    background: var(--gradient-primary);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .ob-band p { font-size: 1.1rem; line-height: 1.7; color: var(--color-text-muted); margin: 0 auto; max-width: 620px; }

  /* ===== Animations ===== */
  @keyframes ob-in { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes ob-ping {
    0% { box-shadow: 0 0 0 0 rgba(239,68,68,0.5); }
    70% { box-shadow: 0 0 0 9px rgba(239,68,68,0); }
    100% { box-shadow: 0 0 0 0 rgba(239,68,68,0); }
  }
  @keyframes ob-sheen { 0%, 60% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

  @media (prefers-reduced-motion: reduce) {
    .ob-live, .ob-title, .ob-tagline, .ob-sub, .ob-cta-row, .ob-meta { animation: none; }
    .ob-live-dot, .ob-btn-pulse { animation: none; }
  }

  @media (max-width: 768px) {
    .ob-hero { padding: calc(var(--header-height) + 2.5rem) 0 3.5rem; }
    .ob-section { padding: 3rem 0; }
    .ob-band { padding: 3.5rem 0; }
  }
</style>
